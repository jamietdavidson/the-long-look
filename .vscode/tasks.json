{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Frontend",
      "type": "npm",
      "script": "dev",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "(Local:|localhost:3002|ready in)"
        }
      }
    }
  ]
}
