{
  "compilerOptions": {
    "checkJs": false,
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "~/*": ["app/*"],
      "@/*": ["app/*"],
      "storefrontapi.generated": ["app/types/storefrontapi.generated.d.ts"],
      "customer-accountapi.generated": [
        "app/types/customer-accountapi.generated.d.ts"
      ]
    }
  },
  "include": [
    "env.d.ts",
    "app/**/*.js",
    "app/**/*.jsx",
    "app/**/*.ts",
    "app/**/*.tsx",
    "app/**/*.d.ts",
    "e2e/**/*.ts",
    "*.js",
    "*.jsx",
    "*.ts",
    "*.d.ts",
    "codegen.ts",
    ".graphqlrc.js",
    ".react-router/types/**/*"
  ]
}
